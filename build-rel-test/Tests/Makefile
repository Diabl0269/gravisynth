# Special targets to cleanup operation of make.

# Special rule to run CMake to check the build system integrity.
# No rule that depends on this can have commands that come from listfiles
# because they might be regenerated.
cmake_check_build_system:
	cd /Users/talef/Documents/projects/prv/gravisynth/.claude/worktrees/vst3-au-plugin/build-rel-test && $(CMAKE_COMMAND) -P /Users/talef/Documents/projects/prv/gravisynth/.claude/worktrees/vst3-au-plugin/build-rel-test/CMakeFiles/VerifyGlobs.cmake
	cd /Users/talef/Documents/projects/prv/gravisynth/.claude/worktrees/vst3-au-plugin/build-rel-test && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
.PHONY : cmake_check_build_system

